{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 2,
	"settings": {
		"layout": {
			"contentSize": "740px",
			"wideSize": "1200px"
		},
		"color": {
			"palette": [
				{
					"slug": "foreground",
					"color": "#000000",
					"name": "Foreground"
				},
				{
					"slug": "background",
					"color": "#ffffff",
					"name": "Background"
				},
				{
					"slug": "muted",
					"color": "#777777",
					"name": "Muted text"
				},
				{
					"slug": "border",
					"color": "#dddddd",
					"name": "Border"
				}
			]
		},
		"typography": {
			"fontFamilies": [
				{
					"fontFamily": "\"Open Sans\", -apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, Oxygen-Sans, Ubuntu, Cantarell, \"Helvetica Neue\", sans-serif",
					"slug": "open-sans",
					"name": "Open Sans"
				}
			],
			"fontSizes": [
				{
					"slug": "small",
					"size": "0.8rem",
					"name": "Small"
				},
				{
					"slug": "medium",
					"size": "1rem",
					"name": "Medium"
				},
				{
					"slug": "body",
					"size": "1.1rem",
					"name": "Body"
				},
				{
					"slug": "h6",
					"size": "1rem",
					"name": "Heading 6"
				},
				{
					"slug": "h5",
					"size": "1.2rem",
					"name": "Heading 5"
				},
				{
					"slug": "h4",
					"size": "1.4rem",
					"name": "Heading 4"
				},
				{
					"slug": "h3",
					"size": "1.6rem",
					"name": "Heading 3"
				},
				{
					"slug": "h2",
					"size": "1.8rem",
					"name": "Heading 2"
				},
				{
					"slug": "h1",
					"size": "2rem",
					"name": "Heading 1"
				}
			]
		}
	}
}
